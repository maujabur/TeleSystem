menu "Web Portal Config"

config WEB_PORTAL_ENABLE_LOGS_ENDPOINT
    bool "Enable /api/logs endpoint"
    default y
    help
        Mantem a API de logs disponivel no portal tecnico. Recomendado
        desativado para builds de release.

config WEB_PORTAL_EXPOSE_NETWORK_IDENTIFIERS
    bool "Expose SSID/IP identifiers in technical APIs"
    default n
    help
        Quando desativado, /api/status e APIs tecnicas relacionadas evitam
        expor SSID/IP/provisioning_ssid diretamente.

config WEB_PORTAL_DETAILED_HTTP_ERRORS
    bool "Return detailed internal errors in HTTP responses"
    default n
    help
        Quando desativado, endpoints tecnicos retornam mensagens genericas
        para falhas internas, reduzindo exposicao de detalhes internos.

config APP_LOG_BUFFER_CAPTURE_DEBUG
    bool "Capture DEBUG/VERBOSE logs in /api/logs buffer"
    default n
    help
        Quando desativado, o buffer usado por /api/logs ignora linhas de
        DEBUG/VERBOSE para reduzir ruido e volume.

endmenu

menu "MQTT Presence Config"

config MQTT_PRESENCE_ENABLED
    bool "Enable MQTT presence and heartbeat"
    default n
    help
        Habilita publicacao de presenca online/offline, heartbeat e canal
        basico de comando MQTT para operacao remota.

config MQTT_BROKER_URI
    string "MQTT broker URI"
    depends on MQTT_PRESENCE_ENABLED
    default ""
    help
        URI do broker MQTT, por exemplo: mqtts://broker.exemplo.com:8883

config MQTT_USERNAME
    string "MQTT username"
    depends on MQTT_PRESENCE_ENABLED
    default ""

config MQTT_PASSWORD
    string "MQTT password"
    depends on MQTT_PRESENCE_ENABLED
    default ""

config MQTT_TOPIC_NAMESPACE
    string "MQTT topic namespace"
    depends on MQTT_PRESENCE_ENABLED
    default "v1/led"
    help
        Prefixo de topicos usado pelo dispositivo. O device_id sera
        anexado automaticamente.

config MQTT_DEVICE_ID_PREFIX
    string "MQTT device ID prefix"
    depends on MQTT_PRESENCE_ENABLED
    default "TeleCafezinho"
    help
        Prefixo usado para montar o device_id publicado em MQTT.

config MQTT_HEARTBEAT_INTERVAL_S
    int "Heartbeat interval (seconds)"
    depends on MQTT_PRESENCE_ENABLED
    range 15 3600
    default 60

config MQTT_KEEPALIVE_S
    int "MQTT keepalive (seconds)"
    depends on MQTT_PRESENCE_ENABLED
    range 15 1200
    default 60

config MQTT_QOS_CRITICAL
    int "QoS for status/state/command"
    depends on MQTT_PRESENCE_ENABLED
    range 0 2
    default 1

config MQTT_QOS_TELEMETRY
    int "QoS for heartbeat/telemetry"
    depends on MQTT_PRESENCE_ENABLED
    range 0 2
    default 0

endmenu

menu "VBAT Monitor Config"

config VBAT_MONITOR_ENABLED
    bool "Enable VBAT monitor"
    default n
    help
        Habilita monitoramento de tensao da bateria por ADC com calibracao.

config VBAT_MONITOR_GPIO
    int "VBAT ADC GPIO"
    depends on VBAT_MONITOR_ENABLED
    range 0 48
    default 1
    help
        GPIO conectada ao divisor resistivo da bateria.

config VBAT_MONITOR_MAX_INTERVAL_S
    int "Max interval without VBAT measurement (seconds)"
    depends on VBAT_MONITOR_ENABLED
    range 0 86400
    default 120
    help
        Tempo maximo sem tentativa de medicao. Use 0 para desabilitar.

config VBAT_MONITOR_ON_BOOT
    bool "Measure at startup"
    depends on VBAT_MONITOR_ENABLED
    default y

config VBAT_MONITOR_ON_BEFORE_WIFI_PS_EXIT
    bool "Measure before leaving Wi-Fi power save"
    depends on VBAT_MONITOR_ENABLED
    default y

config VBAT_MONITOR_ON_AFTER_PRODUCT_TX
    bool "Measure after product transmission"
    depends on VBAT_MONITOR_ENABLED
    default y

config VBAT_MONITOR_ON_AFTER_PRODUCT_ACTIVITY
    bool "Measure after product activity"
    depends on VBAT_MONITOR_ENABLED
    default y

config VBAT_MONITOR_ON_MAX_INTERVAL
    bool "Measure when max interval elapses"
    depends on VBAT_MONITOR_ENABLED
    default y

config VBAT_SHUTDOWN_ENABLED
    bool "Enable low-battery shutdown"
    depends on VBAT_MONITOR_ENABLED
    default y
    help
        Quando habilitado, o sistema desliga os perifericos via POWER_GOOD
        e entra em deep sleep (sem wakeup por timer) ao detectar tensao
        critica por tempo suficiente.

config VBAT_SHUTDOWN_THRESHOLD_MV
    int "Low-battery shutdown threshold (mV)"
    depends on VBAT_SHUTDOWN_ENABLED
    range 2500 4200
    default 3500
    help
        Tensao da bateria abaixo da qual o desligamento e iniciado.
        Recomendado: 3500 mV para Li-Ion/LiPo de celula unica.

config VBAT_SHUTDOWN_DEBOUNCE_MS
    int "Low-battery shutdown debounce time (ms)"
    depends on VBAT_SHUTDOWN_ENABLED
    range 100 10000
    default 1000
    help
        Tempo minimo continuo com tensao abaixo do limiar para confirmar
        desligamento. Evita falsos positivos por quedas de tensao sob carga.

config VBAT_MAINTENANCE_MODE_MAX_MV
    int "Maintenance mode detection threshold (mV)"
    depends on VBAT_SHUTDOWN_ENABLED
    range 0 2000
    default 500
    help
        Se a tensao lida for menor ou igual a este valor, o sistema assume
        modo de manutencao (bateria desconectada) e inibe o desligamento
        automatico por bateria baixa.

config VBAT_MONITOR_RDIV_RVCC
    int "Voltage divider resistor Rvcc (ohms)"
    depends on VBAT_MONITOR_ENABLED
    range 1 1000000
    default 4640
    help
        Resistor entre VCC da bateria e o pino ADC no divisor de tensao.

config VBAT_MONITOR_RDIV_RGND
    int "Voltage divider resistor Rgnd (ohms)"
    depends on VBAT_MONITOR_ENABLED
    range 1 1000000
    default 5620
    help
        Resistor entre o pino ADC e GND no divisor de tensao.

endmenu

menu "POWER_GOOD GPIO Config"

config POWER_GOOD_GPIO_ENABLED
    bool "Enable POWER_GOOD output GPIO"
    default y
    help
        Habilita o sinal POWER_GOOD: GPIO de saida que alimenta perifericos
        externos via MOSFET. Seta alto ao inicializar
        e baixo antes de entrar em deep sleep.

config POWER_GOOD_GPIO
    int "POWER_GOOD GPIO number"
    depends on POWER_GOOD_GPIO_ENABLED
    range 0 48
    default 6
    help
        Numero da GPIO usada como sinal POWER_GOOD.

config POWER_GOOD_ACTIVE_LEVEL
    int "POWER_GOOD active level (1=high, 0=low)"
    depends on POWER_GOOD_GPIO_ENABLED
    range 0 1
    default 1
    help
        Nivel logico que representa "perifericos ligados".
        Use 1 para MOSFET ativo em nivel alto.

endmenu
