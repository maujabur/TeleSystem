    int "Product waiting blink off time (ms)"
    depends on STATUS_LED_ENABLED
    range 10 60000
    default 750

config STATUS_LED_CAPTURE_OVERLAY_ON_MS
    int "Capture overlay pulse on time (ms)"
    depends on STATUS_LED_ENABLED
    range 1 1000
    default 40

config STATUS_LED_CAPTURE_OVERLAY_OFF_MS
    int "Capture overlay pulse off time (ms)"
    depends on STATUS_LED_ENABLED
    range 1 60000
    default 760

config STATUS_LED_LOW_BATTERY_COLOR
    hex "Low battery color RGB"
    depends on STATUS_LED_ENABLED
    default 0xFF2000

config STATUS_LED_LOW_BATTERY_ON_MS
    int "Low battery blink on time (ms)"
    depends on STATUS_LED_ENABLED
    range 10 60000
    default 200

config STATUS_LED_LOW_BATTERY_OFF_MS
    int "Low battery blink off time (ms)"
    depends on STATUS_LED_ENABLED
    range 10 60000
    default 800

endmenu
